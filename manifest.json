{
  "manifest_version": 3,
  "name": "Roblox Wealth Scanner",
  "version": "3.0",
  "description": "Lightning-fast Roblox community wealth scanning",
  "permissions": ["storage"],
  "host_permissions": ["*://*.roblox.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.svg"
  }
}